    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/preview-url-secret": "^4.0.6",
    "@sanity/ui": "^3.2.0",
    "@sanity/util": "^5.25.0",
    "@sanity/uuid": "^3.0.2",
    "@sanity/vision": "^5.25.0",
    "@vercel/analytics": "^2.0.1",
    "@wrksz/themes": "^0.9.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "immer": "^11.1.8",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-sanity": "13.0.0-cache-components.45",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-screen-wake-lock": "^3.1.1",
    "sanity": "5.25.0",
    "sanity-plugin-documents-pane": "^3.0.2",
    "sanity-plugin-iframe-pane": "^5.0.11",
    "sanity-plugin-media": "^4.2.0",
    "schema-dts": "^2.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "use-debounce": "^10.1.1",
    "valibot": "1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.29",
    "concurrently": "^9.2.1",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.1.1",
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "react",
        "react-dom"
      ]
    },
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "framer-motion": "12.7.4",
      "motion-dom": "12.7.4"
    }
  }
